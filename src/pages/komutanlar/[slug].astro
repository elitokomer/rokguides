---
import { getCollection } from 'astro:content';
import CommanderLayout from '../../layouts/CommanderLayout.astro';
import TalentBuilds from '../../components/TalentBuilds.astro';
import AdSlot from '../../components/AdSlot.astro';
import { t } from '../../i18n/ui';

export async function getStaticPaths() {
  const commanders = await getCollection('commanders');
  return commanders.map((commander) => ({
    params: { slug: commander.slug },
    props: { commander },
  }));
}

const { commander } = Astro.props;
const { Content } = await commander.render();
const dict = t('tr');

const talentBuildModules = import.meta.glob('../../data/talent-builds/*.json', { eager: true }) as Record<
  string,
  { default: { builds: { id: string; name: { tr: string; en: string }; image: string }[] } }
>;
const talentBuilds = talentBuildModules[`../../data/talent-builds/${commander.slug}.json`]?.default.builds ?? null;
---

<CommanderLayout
  name={commander.data.name}
  tier={commander.data.tier}
  troopType={commander.data.troopType}
  rarity={commander.data.rarity}
  kvk={commander.data.kvk}
  image={commander.data.image}
  summary={commander.data.summary}
  alternatePath={`/en/commanders/${commander.slug}`}
>
  <Content />

  {commander.data.bestPairings.length > 0 && (
    <p class="not-prose mt-6 text-sm text-muted">
      <span class="font-medium text-foreground">Önerilen eşleşmeler:</span> {commander.data.bestPairings.join(', ')}
    </p>
  )}

  <div class="not-prose mt-12">
    <h2 class="mb-4 font-display text-2xl font-semibold text-accent-purple-light">{dict.common.talentTree}</h2>
    <TalentBuilds builds={talentBuilds} lang="tr" comingSoonText={dict.common.talentComingSoon} />
  </div>

  <div class="not-prose mt-12">
    <AdSlot label="Reklam alanı" />
  </div>
</CommanderLayout>
