---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CommanderCard from '../../components/CommanderCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const commanders = (await getCollection('commanders')).sort((a, b) => a.data.order - b.data.order);
const eras: Array<{ id: 'kvk1' | 'kvk2' | 'kvk3'; label: string }> = [
  { id: 'kvk1', label: 'KvK 1 Dönemi' },
  { id: 'kvk2', label: 'KvK 2 Dönemi' },
  { id: 'kvk3', label: 'KvK 3 Dönemi' },
];

const troopOrder = ['Piyade', 'Süvari', 'Okçu', 'Liderlik', 'Kuşatma'];
const troopTypes = troopOrder.filter((t) => commanders.some((c) => c.data.troopType === t));

const tierOrder = ['S+', 'S', 'A', 'A-', 'B+', 'B'];
const tiers = tierOrder.filter((t) => commanders.some((c) => c.data.tier === t));
---

<BaseLayout
  title="Komutanlar — KvK Dönemine Göre Tier Listesi"
  description="Rise of Kingdoms komutanlarının KvK 1, KvK 2 ve KvK 3 dönemlerine göre tier analizleri, güçlü/zayıf yönleri ve yetenek ağaçları."
>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="font-display text-3xl font-bold text-foreground sm:text-4xl">Komutan Rehberi</h1>
    <p class="mt-2 max-w-2xl text-muted">
      Krallıklar Savaşı dönemine göre gruplanmış komutan analizleri. Her komutanın güçlü/zayıf yönlerini, en iyi
      eşleşmelerini ve yetenek ağacı önceliklerini inceleyin.
    </p>

    <div class="mt-6 flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <span class="mr-1 text-xs font-medium uppercase tracking-wide text-muted">Birlik Tipi</span>
        <button type="button" data-troop-filter="all" class="filter-btn is-active">Tümü</button>
        {troopTypes.map((t) => (
          <button type="button" data-troop-filter={t} class="filter-btn">{t}</button>
        ))}
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="mr-1 text-xs font-medium uppercase tracking-wide text-muted">Tier</span>
        <button type="button" data-tier-filter="all" class="filter-btn is-active">Tümü</button>
        {tiers.map((t) => (
          <button type="button" data-tier-filter={t} class="filter-btn">{t}</button>
        ))}
      </div>
    </div>

    {eras.map((era) => {
      const eraCommanders = commanders.filter((c) => c.data.kvk === era.id);
      if (eraCommanders.length === 0) return null;
      return (
        <section class="mt-12 era-section" id={era.id}>
          <h2 class="font-display text-2xl font-semibold text-accent-purple-light">{era.label}</h2>
          <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {eraCommanders.map((c) => (
              <CommanderCard
                slug={c.slug}
                name={c.data.name}
                tier={c.data.tier}
                troopType={c.data.troopType}
                image={c.data.image}
                summary={c.data.summary}
              />
            ))}
          </div>
          <p class="empty-message mt-5 hidden text-sm text-muted">Bu filtrelere uyan komutan yok.</p>
        </section>
      );
    })}

    <div class="mt-12">
      <AdSlot label="Reklam alanı" />
    </div>
  </div>
</BaseLayout>

<style>
  .filter-btn {
    border-radius: 9999px;
    border-width: 1px;
    border-color: theme('colors.border');
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: theme('colors.muted');
    transition: all 0.15s ease;
  }
  .filter-btn:hover {
    border-color: theme('colors.accent.purple');
    color: theme('colors.foreground');
  }
  .filter-btn.is-active {
    border-color: theme('colors.accent.purple');
    background-color: rgb(139 92 246 / 0.15);
    color: theme('colors.accent.purple-light');
  }
</style>

<script>
  const troopButtons = document.querySelectorAll<HTMLButtonElement>('[data-troop-filter]');
  const tierButtons = document.querySelectorAll<HTMLButtonElement>('[data-tier-filter]');
  const cards = document.querySelectorAll<HTMLAnchorElement>('a[data-troop][data-tier]');
  const eraSections = document.querySelectorAll<HTMLElement>('.era-section');

  let activeTroop = 'all';
  let activeTier = 'all';

  function applyFilters() {
    cards.forEach((card) => {
      const matchesTroop = activeTroop === 'all' || card.dataset.troop === activeTroop;
      const matchesTier = activeTier === 'all' || card.dataset.tier === activeTier;
      card.classList.toggle('hidden', !(matchesTroop && matchesTier));
    });

    eraSections.forEach((section) => {
      const visibleCount = section.querySelectorAll('a[data-troop][data-tier]:not(.hidden)').length;
      const emptyMessage = section.querySelector<HTMLElement>('.empty-message');
      emptyMessage?.classList.toggle('hidden', visibleCount !== 0);
    });
  }

  function setActiveButton(buttons: NodeListOf<HTMLButtonElement>, target: HTMLButtonElement) {
    buttons.forEach((btn) => btn.classList.toggle('is-active', btn === target));
  }

  troopButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeTroop = btn.dataset.troopFilter ?? 'all';
      setActiveButton(troopButtons, btn);
      applyFilters();
    });
  });

  tierButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeTier = btn.dataset.tierFilter ?? 'all';
      setActiveButton(tierButtons, btn);
      applyFilters();
    });
  });
</script>
