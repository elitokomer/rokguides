---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with RoKGuides for suggestions, corrections, or collaboration requests."
  lang="en"
  alternatePath="/iletisim"
>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-3xl font-bold text-foreground">Contact</h1>
    <div class="prose prose-invert prose-headings:font-display prose-headings:text-accent-purple-light mt-8 max-w-none">
      <p>
        For suggestions, correction requests, or collaboration inquiries, you can reach us at the email address
        below:
      </p>
      <p>
        <a href="mailto:info@rokguides.xyz">info@rokguides.xyz</a>
      </p>
    </div>
  </div>
</BaseLayout>
