---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us"
  description="RoKGuides is an independent resource offering guides and commander analyses for Rise of Kingdoms players."
  lang="en"
  alternatePath="/hakkimizda"
>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="font-display text-3xl font-bold text-foreground">About Us</h1>
    <article class="prose prose-invert prose-headings:font-display prose-headings:text-accent-purple-light mt-8 max-w-none">
      <p>
        RoKGuides is an independent guide site created for Rise of Kingdoms players. Our goal is to give newcomers
        clear and accurate information, while giving experienced players strategic depth through commander analyses
        and talent tree data.
      </p>
      <p>
        Rise of Kingdoms is owned by Lilith Games. RoKGuides is not an official Lilith Games product; our content is
        compiled from player experience and community resources.
      </p>
    </article>
  </div>
</BaseLayout>
