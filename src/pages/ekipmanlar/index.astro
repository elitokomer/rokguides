---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import equipmentData from '../../data/equipment.json';

const { levels, troopTypes, sets } = equipmentData;
---

<BaseLayout
  title="Ekipmanlar — Birlik Tipine Göre Ekipman Setleri"
  description="Rise of Kingdoms'ta piyade, okçu ve süvari birlikleri için başlangıç, orta ve son seviye ekipman set önerileri."
>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="font-display text-3xl font-bold text-foreground sm:text-4xl">Ekipmanlar</h1>
    <p class="mt-2 max-w-2xl text-muted">
      Birlik tipine ve oyun seviyenize göre önerilen ekipman setleri. Her set 8 parçadan oluşur; parça rengi
      ekipmanın nadirliğini gösterir.
    </p>

    <div class="mt-6 flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <span class="mr-1 text-xs font-medium uppercase tracking-wide text-muted">Birlik Tipi</span>
        <button type="button" data-troop-filter="all" class="filter-btn is-active">Tümü</button>
        {troopTypes.map((t) => (
          <button type="button" data-troop-filter={t} class="filter-btn">{t}</button>
        ))}
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="mr-1 text-xs font-medium uppercase tracking-wide text-muted">Seviye</span>
        <button type="button" data-level-filter="all" class="filter-btn is-active">Tümü</button>
        {levels.map((l) => (
          <button type="button" data-level-filter={l.id} class="filter-btn">{l.label}</button>
        ))}
      </div>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {troopTypes.map((troop) =>
        levels.map((level) => {
          const matches = sets.filter((s) => s.troopType === troop && s.level === level.id);
          return (
            <div
              class="equipment-card rounded-2xl border border-border bg-surface p-6"
              data-troop={troop}
              data-level={level.id}
            >
              <div class="mb-4 text-center">
                <p class="text-xs font-medium uppercase tracking-wide text-accent-cyan-light">{troop}</p>
                <h2 class="font-display text-lg font-semibold text-foreground">{level.label}</h2>
              </div>
              {matches.length > 0 ? (
                <div class="grid gap-6" style={matches.length > 1 ? 'grid-template-columns: repeat(auto-fit, minmax(160px, 1fr))' : ''}>
                  {matches.map((set) => (
                    <div>
                      {set.variantLabel && (
                        <p class="mb-2 text-center text-xs font-semibold text-accent-purple-light">{set.variantLabel}</p>
                      )}
                      <img
                        src={set.image}
                        alt={`${troop} ${level.label} ekipman seti`}
                        width="320"
                        height="660"
                        class="mx-auto w-full max-w-[220px]"
                      />
                    </div>
                  ))}
                </div>
              ) : (
                <p class="py-10 text-center text-sm text-muted">Bu set için içerik yakında eklenecek.</p>
              )}
            </div>
          );
        })
      )}
    </div>

    <div class="mt-12">
      <AdSlot label="Reklam alanı" />
    </div>
  </div>
</BaseLayout>

<style>
  .filter-btn {
    border-radius: 9999px;
    border-width: 1px;
    border-color: theme('colors.border');
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: theme('colors.muted');
    transition: all 0.15s ease;
  }
  .filter-btn:hover {
    border-color: theme('colors.accent.purple');
    color: theme('colors.foreground');
  }
  .filter-btn.is-active {
    border-color: theme('colors.accent.purple');
    background-color: rgb(139 92 246 / 0.15);
    color: theme('colors.accent.purple-light');
  }
</style>

<script>
  const troopButtons = document.querySelectorAll<HTMLButtonElement>('[data-troop-filter]');
  const levelButtons = document.querySelectorAll<HTMLButtonElement>('[data-level-filter]');
  const cards = document.querySelectorAll<HTMLElement>('.equipment-card');

  let activeTroop = 'all';
  let activeLevel = 'all';

  function applyFilters() {
    cards.forEach((card) => {
      const matchesTroop = activeTroop === 'all' || card.dataset.troop === activeTroop;
      const matchesLevel = activeLevel === 'all' || card.dataset.level === activeLevel;
      card.classList.toggle('hidden', !(matchesTroop && matchesLevel));
    });
  }

  function setActiveButton(buttons: NodeListOf<HTMLButtonElement>, target: HTMLButtonElement) {
    buttons.forEach((btn) => btn.classList.toggle('is-active', btn === target));
  }

  troopButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeTroop = btn.dataset.troopFilter ?? 'all';
      setActiveButton(troopButtons, btn);
      applyFilters();
    });
  });

  levelButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeLevel = btn.dataset.levelFilter ?? 'all';
      setActiveButton(levelButtons, btn);
      applyFilters();
    });
  });
</script>
