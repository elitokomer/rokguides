---
import { t, localizePath, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'tr' } = Astro.props;
const dict = t(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-10 text-sm text-muted">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <p class="font-display text-lg text-gradient">RoKGuides</p>
        <p class="mt-2">{dict.footer.tagline}</p>
      </div>
      <div>
        <p class="mb-2 font-medium text-foreground">{dict.footer.guides}</p>
        <ul class="space-y-1">
          <li><a href={localizePath('/baslangic-rehberi', lang)} class="hover:text-accent-cyan-light">{dict.nav.gettingStarted}</a></li>
          <li><a href={localizePath('/komutanlar', lang)} class="hover:text-accent-cyan-light">{dict.nav.commanders}</a></li>
          <li><a href={localizePath('/ekipmanlar', lang)} class="hover:text-accent-cyan-light">{dict.nav.equipment}</a></li>
        </ul>
      </div>
      <div>
        <p class="mb-2 font-medium text-foreground">{dict.footer.corporate}</p>
        <ul class="space-y-1">
          <li><a href={localizePath('/hakkimizda', lang)} class="hover:text-accent-cyan-light">{dict.nav.about}</a></li>
          <li><a href={localizePath('/iletisim', lang)} class="hover:text-accent-cyan-light">{dict.nav.contact}</a></li>
          <li><a href={localizePath('/gizlilik-politikasi', lang)} class="hover:text-accent-cyan-light">{dict.footer.privacyPolicy}</a></li>
        </ul>
      </div>
    </div>
    <p class="mt-8 border-t border-border pt-6 text-xs">
      {dict.footer.copyright(year)}
    </p>
  </div>
</footer>
