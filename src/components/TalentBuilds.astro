---
import { type Lang } from '../i18n/ui';

interface Build {
  id: string;
  name: { tr: string; en: string };
  image: string;
}

interface Props {
  builds: Build[] | null;
  lang?: Lang;
  comingSoonText: string;
}

const { builds, lang = 'tr', comingSoonText } = Astro.props;
---

{builds && builds.length > 0 ? (
  <div class="talent-builds-widget">
    {builds.length > 1 && (
      <div class="mb-5 flex flex-wrap justify-center gap-2">
        {builds.map((build, i) => (
          <button
            type="button"
            data-build-tab={build.id}
            class={`build-tab-btn ${i === 0 ? 'is-active' : ''}`}
          >
            {build.name[lang]}
          </button>
        ))}
      </div>
    )}

    {builds.map((build, i) => (
      <div class="build-panel" data-build-panel={build.id} style={i === 0 ? '' : 'display:none'}>
        <div class="relative mx-auto aspect-[4/3] w-full max-w-2xl overflow-hidden rounded-xl border border-border bg-surface-alt">
          <img
            src={build.image}
            alt={build.name[lang]}
            loading="lazy"
            class="h-full w-full object-contain"
          />
        </div>
      </div>
    ))}
  </div>
) : (
  <p class="py-8 text-center text-sm text-muted">{comingSoonText}</p>
)}

<style>
  .build-tab-btn {
    border-radius: 9999px;
    border-width: 1px;
    border-color: theme('colors.border');
    padding: 0.375rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: theme('colors.muted');
    transition: all 0.15s ease;
  }
  .build-tab-btn:hover {
    border-color: theme('colors.accent.purple');
    color: theme('colors.foreground');
  }
  .build-tab-btn.is-active {
    border-color: theme('colors.accent.purple');
    background-color: rgb(139 92 246 / 0.15);
    color: theme('colors.accent.purple-light');
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.talent-builds-widget').forEach((widget) => {
    const tabs = widget.querySelectorAll<HTMLButtonElement>('[data-build-tab]');
    const panels = widget.querySelectorAll<HTMLElement>('[data-build-panel]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.dataset.buildTab;
        tabs.forEach((t) => t.classList.toggle('is-active', t === tab));
        panels.forEach((p) => {
          p.style.display = p.dataset.buildPanel === targetId ? '' : 'none';
        });
      });
    });
  });
</script>
