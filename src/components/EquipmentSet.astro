---
interface Piece {
  slot: string;
  rarity: string;
}

interface Props {
  pieces: Piece[];
}

const { pieces } = Astro.props;

const rarityClass: Record<string, string> = {
  yesil: 'border-rarity-yesil shadow-[0_0_14px_-4px_rgba(74,222,128,0.7)]',
  mavi: 'border-rarity-mavi shadow-[0_0_14px_-4px_rgba(96,165,250,0.7)]',
  mor: 'border-rarity-mor shadow-[0_0_14px_-4px_rgba(167,139,250,0.7)]',
  turuncu: 'border-rarity-turuncu shadow-[0_0_14px_-4px_rgba(251,146,60,0.7)]',
};

const [helmet, chest, weapon, gloves, belt, necklace, banner, boots] = pieces;
---

<div class="flex flex-col items-center">
  {helmet && (
    <div class={`equip-tile ${rarityClass[helmet.rarity]}`}><span>{helmet.slot}</span></div>
  )}
  {chest && (
    <div class={`equip-tile -mt-3 ${rarityClass[chest.rarity]}`}><span>{chest.slot}</span></div>
  )}
  <div class="-mt-3 flex gap-6">
    {weapon && <div class={`equip-tile ${rarityClass[weapon.rarity]}`}><span>{weapon.slot}</span></div>}
    {gloves && <div class={`equip-tile ${rarityClass[gloves.rarity]}`}><span>{gloves.slot}</span></div>}
  </div>
  {belt && (
    <div class={`equip-tile -mt-3 ${rarityClass[belt.rarity]}`}><span>{belt.slot}</span></div>
  )}
  <div class="-mt-3 flex gap-6">
    {necklace && <div class={`equip-tile ${rarityClass[necklace.rarity]}`}><span>{necklace.slot}</span></div>}
    {banner && <div class={`equip-tile ${rarityClass[banner.rarity]}`}><span>{banner.slot}</span></div>}
  </div>
  {boots && (
    <div class={`equip-tile -mt-3 ${rarityClass[boots.rarity]}`}><span>{boots.slot}</span></div>
  )}
</div>

<style>
  .equip-tile {
    width: 5.5rem;
    height: 5.5rem;
    border-width: 2px;
    border-radius: 0.5rem;
    background-color: theme('colors.surface-alt');
    transform: rotate(45deg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .equip-tile span {
    display: block;
    transform: rotate(-45deg);
    font-size: 0.6875rem;
    font-weight: 600;
    text-align: center;
    color: theme('colors.foreground');
    line-height: 1.1;
    width: 4.2rem;
  }
</style>
