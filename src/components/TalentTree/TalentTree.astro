---
import type { TalentTreeData } from './talent-tree.types';

interface Props {
  data: TalentTreeData;
  portraitSrc: string;
  portraitAlt: string;
}

const { data, portraitSrc, portraitAlt } = Astro.props;
---

<div class="relative mx-auto aspect-square w-full max-w-2xl">
  <svg viewBox="0 0 100 100" class="h-full w-full" role="img" aria-label={`${data.commander} yetenek ağacı`}>
    {data.branches.map((branch) => (
      <g>
        {branch.nodes.map((node) =>
          node.connections.map((targetId) => {
            const target = branch.nodes.find((n) => n.id === targetId);
            if (!target) return null;
            return (
              <line
                x1={node.x}
                y1={node.y}
                x2={target.x}
                y2={target.y}
                stroke={branch.color}
                stroke-width="0.4"
                opacity="0.5"
              />
            );
          })
        )}
      </g>
    ))}
    {data.branches.map((branch) => (
      <g>
        {branch.nodes.map((node) => (
          <g>
            <circle cx={node.x} cy={node.y} r="3.2" fill="#12172a" stroke={branch.color} stroke-width="0.6" />
            <text
              x={node.x}
              y={node.y + 6.5}
              text-anchor="middle"
              font-size="2.4"
              fill="#eef1fa"
              class="font-body"
            >
              {node.label}
            </text>
            <text
              x={node.x}
              y={node.y + 0.9}
              text-anchor="middle"
              font-size="2"
              fill={branch.color}
              class="font-body"
            >
              {node.rank}
            </text>
          </g>
        ))}
      </g>
    ))}
    <circle cx="50" cy="50" r="8" fill="#0a0e1a" stroke="#8b5cf6" stroke-width="0.8" />
  </svg>
  <img
    src={portraitSrc}
    alt={portraitAlt}
    width="64"
    height="64"
    loading="lazy"
    class="pointer-events-none absolute left-1/2 top-1/2 h-[13%] w-[13%] -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-accent-purple object-cover"
  />
  <ul class="mt-4 flex flex-wrap justify-center gap-4 text-sm">
    {data.branches.map((branch) => (
      <li class="flex items-center gap-2">
        <span class="h-3 w-3 rounded-full" style={`background-color:${branch.color}`}></span>
        <span class="text-muted">{branch.name}</span>
      </li>
    ))}
  </ul>
</div>
