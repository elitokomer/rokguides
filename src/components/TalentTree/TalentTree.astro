---
import type { TalentTreeData } from './talent-tree.types';

interface Props {
  data: TalentTreeData;
  portraitSrc: string;
  portraitAlt: string;
}

const { data, portraitSrc, portraitAlt } = Astro.props;
---

<div class="talent-tree-widget">
  {data.builds.length > 1 && (
    <div class="mb-5 flex flex-wrap justify-center gap-2">
      {data.builds.map((build, i) => (
        <button
          type="button"
          data-build-tab={build.id}
          class={`build-tab-btn ${i === 0 ? 'is-active' : ''}`}
        >
          {build.name}
        </button>
      ))}
    </div>
  )}

  {data.builds.map((build, i) => (
    <div class="build-panel" data-build-panel={build.id} style={i === 0 ? '' : 'display:none'}>
      <div class="relative mx-auto aspect-square w-full max-w-2xl">
        <svg viewBox="0 0 100 100" class="h-full w-full" role="img" aria-label={`${data.commander} - ${build.name} yetenek ağacı`}>
          {build.branches.map((branch) => (
            <g>
              {branch.nodes.map((node) =>
                node.connections.map((targetId) => {
                  const target = branch.nodes.find((n) => n.id === targetId);
                  if (!target) return null;
                  return (
                    <line
                      x1={node.x}
                      y1={node.y}
                      x2={target.x}
                      y2={target.y}
                      stroke={branch.color}
                      stroke-width="0.4"
                      opacity="0.5"
                    />
                  );
                })
              )}
            </g>
          ))}
          {build.branches.map((branch) => (
            <g>
              {branch.nodes.map((node) => (
                <g>
                  <circle cx={node.x} cy={node.y} r="3.2" fill="#12172a" stroke={branch.color} stroke-width="0.6" />
                  <text
                    x={node.x}
                    y={node.y + 6.5}
                    text-anchor="middle"
                    font-size="2.4"
                    fill="#eef1fa"
                    class="font-body"
                  >
                    {node.label}
                  </text>
                  <text
                    x={node.x}
                    y={node.y + 0.9}
                    text-anchor="middle"
                    font-size="2"
                    fill={branch.color}
                    class="font-body"
                  >
                    {node.rank}
                  </text>
                </g>
              ))}
            </g>
          ))}
          <circle cx="50" cy="50" r="8" fill="#0a0e1a" stroke="#8b5cf6" stroke-width="0.8" />
        </svg>
        <img
          src={portraitSrc}
          alt={portraitAlt}
          width="64"
          height="64"
          loading="lazy"
          class="pointer-events-none absolute left-1/2 top-1/2 h-[13%] w-[13%] -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-accent-purple bg-surface-alt object-cover object-top"
        />
        <ul class="mt-4 flex flex-wrap justify-center gap-4 text-sm">
          {build.branches.map((branch) => (
            <li class="flex items-center gap-2">
              <span class="h-3 w-3 rounded-full" style={`background-color:${branch.color}`}></span>
              <span class="text-muted">{branch.name}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  ))}
</div>

<style>
  .build-tab-btn {
    border-radius: 9999px;
    border-width: 1px;
    border-color: theme('colors.border');
    padding: 0.375rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: theme('colors.muted');
    transition: all 0.15s ease;
  }
  .build-tab-btn:hover {
    border-color: theme('colors.accent.purple');
    color: theme('colors.foreground');
  }
  .build-tab-btn.is-active {
    border-color: theme('colors.accent.purple');
    background-color: rgb(139 92 246 / 0.15);
    color: theme('colors.accent.purple-light');
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.talent-tree-widget').forEach((widget) => {
    const tabs = widget.querySelectorAll<HTMLButtonElement>('[data-build-tab]');
    const panels = widget.querySelectorAll<HTMLElement>('[data-build-panel]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.dataset.buildTab;
        tabs.forEach((t) => t.classList.toggle('is-active', t === tab));
        panels.forEach((p) => {
          p.style.display = p.dataset.buildPanel === targetId ? '' : 'none';
        });
      });
    });
  });
</script>
